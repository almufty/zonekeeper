
# Server port (default: 3000)
PORT=3000

# SQLite database path (default: ./zonekeeper.db next to server.js)
DB_PATH=./zonekeeper.db

# Sync interval in seconds (minimum: 60, default: 300 = 5 minutes)
POLL_INTERVAL=300

# How many days of sync history to keep (default: 30)
LOG_RETENTION_DAYS=30

# ─────────────────────────────────────────────
# REQUIRED IN PRODUCTION
# ─────────────────────────────────────────────

# Session secret — must be set in production; generates ephemeral key in dev if absent.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Encryption key for Cloudflare API credentials stored in the database.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes). Without this, keys are stored in plaintext.
ENCRYPTION_KEY=

# ─────────────────────────────────────────────
# OPTIONAL
# ─────────────────────────────────────────────

# Admin account for first-run setup (password is auto-generated and printed if not set)
ADMIN_USER=admin
ADMIN_PASS=

# HTTP Basic Auth — both must be set to enable; leave blank to disable
AUTH_USER=
AUTH_PASS=

# Log level: error | warn | info | debug  (default: info)
LOG_LEVEL=info

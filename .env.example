
# Server port (default: 3000)
PORT=3000

# SQLite database path (default: ./zonekeeper.db next to server.js)
DB_PATH=./zonekeeper.db

# Sync interval in seconds (default: 300 = 5 minutes)
POLL_INTERVAL=300

# Session secret — set a long random string to keep sessions across restarts
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Admin account for first-run setup (if not set, a password is auto-generated and printed to console)
ADMIN_USER=admin
ADMIN_PASS=

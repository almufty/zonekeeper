
# Server port (default: 3000)
PORT=3000

# SQLite database path (default: ./zonekeeper.db next to server.js)
DB_PATH=./zonekeeper.db

# Sync interval in seconds (minimum: 60, default: 300 = 5 minutes)
POLL_INTERVAL=300

# How many days of sync history to keep (default: 30)
LOG_RETENTION_DAYS=30

# ─────────────────────────────────────────────
# REQUIRED IN PRODUCTION
# ─────────────────────────────────────────────

# Session secret — REQUIRED in production (must be a unique random string of at
# least 32 characters; known placeholders are rejected). Generates an ephemeral
# key in dev if absent.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Encryption key for Cloudflare API credentials stored in the database.
# REQUIRED in production — startup fails without it. Must be exactly 64 hex
# characters (32 bytes). In dev, keys are stored in plaintext if absent.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Number of reverse-proxy hops to trust for client IP / HTTPS detection.
# Default: 1 (typical single reverse proxy). Use 'false' if exposed directly.
TRUST_PROXY=1

# ─────────────────────────────────────────────
# OPTIONAL
# ─────────────────────────────────────────────

# Admin account for first-run setup (password is auto-generated and printed if not set)
ADMIN_USER=admin
ADMIN_PASS=

# Log level: error | warn | info | debug  (default: info)
LOG_LEVEL=info
